{
  "name": "yt-dimmer",
  "displayName": "YouTube dimmer",
  "version": "0.0.1",
  "description": "A small extension that adds the function of dimming everything around the video you currently watch on YouTube.",
  "author": "3450d",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "^0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": ["activeTab"],
    "host_permissions": ["*://www.youtube.com/*"]
  }
}
